# MongoDB Configuration
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=guardianeye

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# CORS Configuration (for frontend)
FRONTEND_URL=http://localhost:3000

# Alert Services (Mock for demo)
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_token_here
TWILIO_PHONE_NUMBER=+1234567890

# File Upload
MAX_FILE_SIZE=10485760
EVIDENCE_DIR=./evidence

# Cloudinary (evidence image cloud storage)
# Sign up at https://cloudinary.com (free tier is sufficient)
# Find these values in your Cloudinary Dashboard → Settings → API Keys
# Leave blank to fall back to local file serving (evidence will still be saved locally)
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
CLOUDINARY_FOLDER=guardianeye/evidence
